# ==============================================================================
# Security Headers & HSTS
# ==============================================================================
<IfModule mod_headers.c>
  Header set X-Content-Type-Options "nosniff"
  Header set X-Frame-Options "SAMEORIGIN"
  Header set Referrer-Policy "strict-origin-when-cross-origin"
  Header set Permissions-Policy "geolocation=(), microphone=(), camera=()"
  
  # HSTS (Enable after HTTPS SSL certificate is active)
  Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
</IfModule>

# ==============================================================================
# 301 Redirects: Standardize .html -> .php (Prevent Duplicate Content)
# ==============================================================================
<IfModule mod_rewrite.c>
  RewriteEngine On
  
  # Redirect direct request for index.html or index.php to root /
  RewriteCond %{THE_REQUEST} ^[A-Z]{3,9}\ /index\.(html|php)\ HTTP/
  RewriteRule ^index\.(html|php)$ https://samartheggscenter.com/ [R=301,L]

  # Redirect .html extension requests to .php on PHP servers
  RewriteCond %{THE_REQUEST} \s/+(.+)\.html[\s?] [NC]
  RewriteRule ^ /%1.php [R=301,L]
</IfModule>

# ==============================================================================
# GZIP / Brotli Compression
# ==============================================================================
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css text/javascript application/javascript application/x-javascript application/json application/xml image/svg+xml
</IfModule>

# ==============================================================================
# Leverage Browser Caching (Expires Headers)
# ==============================================================================
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresDefault "access plus 1 month"
  
  # CSS and JavaScript
  ExpiresByType text/css "access plus 1 year"
  ExpiresByType text/javascript "access plus 1 year"
  ExpiresByType application/javascript "access plus 1 year"
  
  # WebP and Images
  ExpiresByType image/webp "access plus 1 year"
  ExpiresByType image/png "access plus 1 year"
  ExpiresByType image/jpg "access plus 1 year"
  ExpiresByType image/jpeg "access plus 1 year"
  ExpiresByType image/svg+xml "access plus 1 year"
  ExpiresByType image/x-icon "access plus 1 year"
  
  # Fonts
  ExpiresByType font/woff2 "access plus 1 year"
  ExpiresByType font/woff "access plus 1 year"
</IfModule>
